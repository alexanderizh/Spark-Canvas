{
  "name": "@spark/desktop",
  "version": "0.5.1",
  "description": "Spark Canvas video workbench - Electron + React + TypeScript",
  "author": "Spark Canvas Team",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "pnpm run prepare:file-viewer-assets && electron-vite dev --watch",
    "dev:rebuild": "pnpm run rebuild:native",
    "verify:migrations": "node ../../packages/storage/scripts/verify-migrations.mjs",
    "build": "pnpm run verify:migrations && pnpm run prepare:file-viewer-assets && electron-vite build",
    "build:unpack": "pnpm run build && pnpm run rebuild:native && electron-builder --dir",
    "build:prod": "pnpm run build && pnpm run rebuild:native && electron-builder",
    "build:win": "bash scripts/build-win-release.sh x64 --publish never",
    "cert:win:self-signed": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-windows-self-signed-cert.ps1",
    "build:mac": "pnpm run build && pnpm run rebuild:native -- arm64 && electron-builder --mac --arm64 && pnpm run rebuild:native -- x64 && electron-builder --mac --x64",
    "build:mac:arm64": "pnpm run build && pnpm run rebuild:native -- arm64 && electron-builder --mac --arm64",
    "build:mac:x64": "pnpm run build && pnpm run rebuild:native -- x64 && electron-builder --mac --x64",
    "build:win:release": "bash scripts/build-win-release.sh x64",
    "build:linux": "pnpm run build && pnpm run rebuild:native && electron-builder --linux",
    "build:all": "echo \"build:all is disabled because native modules must be rebuilt on each target OS/arch runner; use the release workflow instead.\" && exit 1",
    "pack": "pnpm run verify:migrations && pnpm run prepare:file-viewer-assets && electron-builder --dir",
    "preview": "electron-vite preview",
    "download-browser": "node scripts/download-browser.js",
    "rebuild:native": "bash scripts/rebuild-native-for-electron.sh",
    "native:verify": "electron scripts/verify-native-electron-abi.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .ts,.tsx",
    "i18n:scan": "node scripts/scan-client-i18n.mjs",
    "prepare:file-viewer-assets": "node scripts/copy-file-viewer-assets.mjs"
  },
  "//deps-note": "dependencies 仅保留 main/preload 运行时真正 require 的包（已据 out/main bundle 权威核实）。所有纯渲染端依赖被 vite 打进 out/renderer，移到 devDependencies，使 electron-builder 仅收生产依赖闭包，避免渲染库及其传递依赖被重复打包。配合 pnpm nodeLinker:hoisted 平铺布局，electron-builder 才能完整收集生产闭包。",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.66.1",
    "@napi-rs/canvas": "1.0.0",
    "@openai/codex-sdk": "0.143.0",
    "@playwright/mcp": "^0.0.30",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "js-yaml": "^4.1.1",
    "keytar": "^7.9.0",
    "mammoth": "^1.12.0",
    "npm": "10.9.2",
    "openai": "^6.39.0",
    "playwright": "^1.49.0",
    "sqlite-vec": "0.1.9",
    "three": "^0.185.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@electron/rebuild": "4.2.0",
    "@eslint/js": "^10.0.1",
    "@file-viewer/core": "^2.0.8",
    "@file-viewer/react": "^2.0.8",
    "@file-viewer/web": "^2.0.8",
    "@lexical/react": "^0.47.0",
    "@lobehub/emojilib": "^1.0.0",
    "@lobehub/fluent-emoji": "^4.1.0",
    "@lobehub/icons": "^5.10.0",
    "@lobehub/ui": "^5.15.15",
    "@lobehub/webfont-geist": "^1.0.0",
    "@lobehub/webfont-geist-mono": "^1.0.0",
    "@lobehub/webfont-harmony-sans-sc": "^1.0.0",
    "@playwright/test": "^1.45.0",
    "@rc-component/qrcode": "^1.1.1",
    "@spark/agent-runtime": "workspace:*",
    "@spark/protocol": "workspace:*",
    "@spark/shared": "workspace:*",
    "@spark/storage": "workspace:*",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-virtual": "^3.14.5",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@xyflow/react": "^12.3.5",
    "antd": "^6.4.4",
    "electron": "^41.10.3",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fabric": "^7.4.0",
    "html2canvas": "^1.4.1",
    "katex": "^0.17.0",
    "less": "^4.6.4",
    "lexical": "^0.47.0",
    "lucide-react": "^1.16.0",
    "motion": "^12.40.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^5.5.0",
    "react-router-dom": "^7.15.1",
    "shiki": "^4.2.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^2.0.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.210",
    "@anthropic-ai/claude-agent-sdk-darwin-arm64": "0.3.210",
    "@anthropic-ai/claude-agent-sdk-darwin-x64": "0.3.210",
    "@anthropic-ai/claude-agent-sdk-linux-arm64": "0.3.210",
    "@anthropic-ai/claude-agent-sdk-linux-arm64-musl": "0.3.210",
    "@anthropic-ai/claude-agent-sdk-linux-x64": "0.3.210",
    "@anthropic-ai/claude-agent-sdk-linux-x64-musl": "0.3.210",
    "@anthropic-ai/claude-agent-sdk-win32-arm64": "0.3.210",
    "@anthropic-ai/claude-agent-sdk-win32-x64": "0.3.210"
  }
}
