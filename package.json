{
  "name": "spark-agent",
  "version": "0.1.20",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "description": "Spark Agent — Local-first AI Agent desktop workbench",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.14.0 <23",
    "pnpm": ">=11.7.0 <12"
  },
  "scripts": {
    "dev": "cd apps/desktop && pnpm run dev",
    "dev:rebuild": "cd apps/desktop && pnpm run dev:rebuild",
    "build": "pnpm --filter @spark/desktop build",
    "test": "pnpm -r run test",
    "test:unit": "pnpm -r run test:unit",
    "test:e2e": "pnpm --filter @spark/desktop test:e2e",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "clean": "pnpm -r run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  }
}
