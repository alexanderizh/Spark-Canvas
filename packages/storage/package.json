{
  "name": "@spark/storage",
  "version": "0.1.0",
  "description": "Spark Agent storage layer — better-sqlite3, WAL mode, SQL migrations, repository pattern",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./migrations": "./src/migrations/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test:unit": "../../scripts/sqlite-abi.sh node && vitest run; s=$?; ../../scripts/sqlite-abi.sh electron; exit $s",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@spark/shared": "workspace:*",
    "better-sqlite3": "^12.10.0",
    "sqlite-vec": "0.1.9",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
