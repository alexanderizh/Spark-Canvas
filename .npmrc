; Spark Agent pnpm 配置

; 原生模块构建批准（better-sqlite3、keytar、esbuild）
; 这些是必须的原生 N-API 模块，需要在安装时编译
approve-only-built-dependencies[]=better-sqlite3
approve-only-built-dependencies[]=esbuild
approve-only-built-dependencies[]=keytar

; Electron 相关
; 在 CI 环境中跳过 Electron 二进制下载（改用缓存）
; ELECTRON_SKIP_BINARY_DOWNLOAD=1

; 使用 shamefully-hoist 确保 Electron 可以访问 node_modules
; （electron-vite 需要）
shamefully-hoist=true
